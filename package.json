{
  "name": "Scribe",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:next": "next dev --turbopack -p 3000",
    "dev:electron": "wait-on http://localhost:3000 && cross-env NODE_ENV=development electron dist-electron/main.js",
    "dev": "npm run build:electron && concurrently -k -n NEXT,ELECTRON -c blue,magenta \"npm:dev:next\" \"npm:dev:electron\"",
    "build:next": "next build",
    "build:electron": "tsc -p electron && cp electron/llm-worker.cjs dist-electron/",
    "build": "npm run build:next && npm run build:electron",
    "start": "electron dist-electron/main.js",
    "bootstrap:python": "./scripts/bootstrap-python.sh",
    "dist": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64",
    "release": "npm run bootstrap:python && npm run dist && ./scripts/install-to-applications.sh",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@tanstack/react-virtual": "^3.13.25",
    "@types/ffmpeg-static": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "node-llama-cpp": "^3.18.1",
    "nodejs-whisper": "^0.3.0",
    "react": "^19.2.4",
    "react-arborist": "^3.7.0",
    "react-dom": "^19.2.4",
    "react-virtualized-auto-sizer": "^2.0.3",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.10"
  }
}
